* text=auto

# Large IQ datasets stay in Git LFS.
datasets/**/*.wav filter=lfs diff=lfs merge=lfs -text
datasets/**/*.ci16 filter=lfs diff=lfs merge=lfs -text
datasets/**/*.cu8 filter=lfs diff=lfs merge=lfs -text
datasets/**/*.cf32 filter=lfs diff=lfs merge=lfs -text

# Engineering sources and metadata must remain LF on Windows checkouts.
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.tcl text eol=lf
*.xdc text eol=lf
*.v text eol=lf
*.sv text eol=lf
*.mem text eol=lf
*.s1p text eol=lf
*.s2p text eol=lf

# Generated and measurement binaries must never be newline-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.bit binary
*.bin binary
*.slx binary
